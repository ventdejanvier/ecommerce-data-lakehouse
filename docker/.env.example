# DEVELOPMENT-ONLY defaults. Copy to docker/.env and replace all passwords
# before any shared, remote, or production-like deployment.
MODEL_DB_NAME=data_lakehouse
MODEL_DB_USER=user
MODEL_DB_PASSWORD=change-me-for-nonlocal-use
MODEL_DB_HOST_PORT=5434

MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=change-me-for-nonlocal-use

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-for-nonlocal-use
AIRFLOW_UID=50000
# On Linux, set this to the group ID that owns /var/run/docker.sock.
DOCKER_GID=0

HIVE_DB_USER=hive
HIVE_DB_PASSWORD=change-me-for-nonlocal-use
HIVE_DB_NAME=metastore_db

# Rollout controls remain disabled until migration and acceptance checks pass.
MODEL_PUBLICATION_V2_ENABLED=false
MODEL_PUBLICATION_AUTO_PUBLISH=false
MODEL_PUBLICATION_LOCK_TIMEOUT_MS=30000
MODEL_PUBLICATION_STATEMENT_TIMEOUT_MS=120000

# Explicitly maps the Docker endpoint to the host endpoint for identity checks.
MODEL_PUBLICATION_DB_ENDPOINT_ALIASES=postgres:5432=localhost:5434
